# AI公司企业管理平台

PORT=3000
NODE_ENV=development

# 数据库路径（SQLite）
DB_PATH=./data/ai-agency.db

# API密钥加密密钥
ENCRYPTION_KEY=change-this-to-a-random-string

# 默认LLM API密钥（可选，也可在应用内按公司配置）
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=

# Ollama本地服务地址
OLLAMA_BASE_URL=http://localhost:11434

# MCP服务器相关
GITHUB_TOKEN=
BRAVE_SEARCH_API_KEY=
